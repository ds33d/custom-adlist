/ip/firewall/address-list/remove [ find where list="ads-blocklist-ip" ];
:global addBlocklistIP;
:set addBlocklistIP do={
    :do { /ip/firewall/address-list/add list=adlist-block address=$1 comment="$2" timeout=$3; } on-error={ }
}

/ipv6/firewall/address-list/remove [ find where list="ads-blocklist-ip" ];
:global addBlocklistIPv6;
:set addBlocklistIPv6 do={
    :do { /ipv6/firewall/address-list/add list=adlist-block address=$1 comment="$2" timeout=$3; } on-error={ }
}

